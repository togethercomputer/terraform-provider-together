#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/togethercomputer/together-go,github.com/stainless-sdks/togetherai-go"

REPLACEMENT="${1:-"../together-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
go mod edit -replace github.com/togethercomputer/together-go="$REPLACEMENT"
go mod tidy -e
